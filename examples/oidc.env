# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

PAPERLESS_MCP_BASE_URL=https://mcp.example.com
PAPERLESS_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
PAPERLESS_MCP_OIDC_CLIENT_ID=mcp-client
PAPERLESS_MCP_OIDC_CLIENT_SECRET=your-client-secret
PAPERLESS_MCP_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
PAPERLESS_MCP_READ_ONLY=false
