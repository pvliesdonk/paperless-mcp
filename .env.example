# Paperless MCP environment variables (copy to .env and fill in).

# --- Server ---
# PAPERLESS_MCP_TRANSPORT=stdio   # stdio | http | sse
# PAPERLESS_MCP_HOST=127.0.0.1
# PAPERLESS_MCP_PORT=8000
# PAPERLESS_MCP_HTTP_PATH=/mcp
# PAPERLESS_MCP_BASE_URL=https://mcp.example.com

# --- Auth (pick one flavor) ---
# PAPERLESS_MCP_BEARER_TOKEN=<secret>

# PAPERLESS_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# PAPERLESS_MCP_OIDC_CLIENT_ID=<client-id>
# PAPERLESS_MCP_OIDC_CLIENT_SECRET=<client-secret>
# PAPERLESS_MCP_OIDC_AUDIENCE=
# PAPERLESS_MCP_OIDC_REQUIRED_SCOPES=openid
# PAPERLESS_MCP_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Domain (populate from your ProjectConfig) ---

# --- Paperless ---
PAPERLESS_MCP_PAPERLESS_URL=http://paperless:8000
PAPERLESS_MCP_API_TOKEN=<your-token>
# Optional: public Paperless UI URL for user-visible links (web_url, share_url).
# Defaults to PAPERLESS_MCP_PAPERLESS_URL if unset.
# PAPERLESS_MCP_PAPERLESS_PUBLIC_URL=https://docs.example.com
