{
  "manifest_version": "0.4",
  "name": "paperless-mcp",
  "display_name": "Paperless MCP",
  "version": "${VERSION}",
  "description": "Paperless-NGX document management over MCP: search, tag, upload, and read documents; manage tags, correspondents, document types, and custom fields.",
  "long_description": "Paperless-NGX document management over MCP: search, tag, upload, and read documents; manage tags, correspondents, document types, and custom fields.",
  "author": {
    "name": "pvliesdonk",
    "url": "https://github.com/pvliesdonk"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pvliesdonk/paperless-mcp.git"
  },
  "homepage": "https://pvliesdonk.github.io/paperless-mcp/",
  "documentation": "https://pvliesdonk.github.io/paperless-mcp/",
  "support": "https://github.com/pvliesdonk/paperless-mcp/issues",
  "license": "UNLICENSED",
  "keywords": [],
  "server": {
    "type": "uv",
    "entry_point": "src/server.py",
    "mcp_config": {
      "command": "uvx",
      "args": ["--from", "pvliesdonk-paperless-mcp[all]==${VERSION}", "paperless-mcp", "serve"],
      "env": {
        "PAPERLESS_MCP_SERVER_NAME": "${user_config.server_name}",
        "PAPERLESS_MCP_READ_ONLY":   "${user_config.read_only}",
        "FASTMCP_LOG_LEVEL":            "${user_config.log_level}"
      }
    }
  },
  "user_config": {
    "server_name": {
      "type": "string",
      "title": "Server name",
      "description": "Name shown in the Claude tool list.",
      "required": false,
      "default": "paperless-mcp"
    },
    "read_only": {
      "type": "boolean",
      "title": "Read-only mode",
      "description": "When true, write-tagged tools are hidden.",
      "required": false,
      "default": true
    },
    "log_level": {
      "type": "string",
      "title": "Log level",
      "description": "One of: DEBUG, INFO, WARNING, ERROR.",
      "required": false,
      "default": "INFO"
    }
  },
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": ["darwin", "win32", "linux"],
    "runtimes": {
      "python": ">=3.11,<4.0"
    }
  }
}
